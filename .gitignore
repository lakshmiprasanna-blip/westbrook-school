# --------------------
# Dependencies
# --------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --------------------
# Testing
# --------------------
coverage/

# --------------------
# Next.js
# --------------------
.next/
out/
build/

# --------------------
# Production / Platform
# --------------------
.vercel/

# --------------------
# Environment variables (IMPORTANT)
# --------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

